{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    }
  },
  "default_agent": "plan",
  "instructions": [
    "AGENTS.md",
    ".agents/rules/constitution.md",
    ".agents/rules/karpathy-guidelines.md",
    ".agents/rules/artifacts-always-first.md",
    ".agents/rules/code-standards.md",
    ".agents/rules/adk_file_formating.md",
    ".agents/rules/bmad_code_review_fast_path.md",
    ".agents/rules/collaborative-debug-first.md",
    ".agents/rules/credential-resolution.md",
    ".agents/rules/dependency-awareness.md",
    ".agents/rules/powershell-encoding-safety.md",
    ".agents/rules/pyrefly-paths.md",
    ".agents/rules/useEffect-dep-array-stability.md",
    ".agents/rules/voice-agent-architecture.md",
    ".agents/rules/prompt-tdd.md",
    ".agents/rules/constitution.project.md",
    "_bmad-output/project-context.md"
  ],
  "skills": {
    "paths": [
      ".agents/skills"
    ]
  },
  "permission": {
    "edit": {
      "_artifacts/**": "allow",
      "*": "ask"
    },
    "webfetch": "allow",
    "bash": {
      "*": "allow",
      "git push *": "ask",
      "git reset --hard *": "ask",
      "git commit *": "ask",
      "git rebase *": "ask",
      "rm *": "ask",
      "Remove-Item *": "ask",
      "del *": "ask",
      "taskkill *": "ask",
      "npm install *": "ask",
      "npm i *": "ask",
      "pip install *": "ask",
      "uv add *": "ask",
      "uv remove *": "ask",
      "firebase deploy *": "ask",
      "gcloud *": "ask"
    },
    "external_directory": {
      "*": "ask",
      "~/.config/opencode/**": "allow"
    }
  }
}